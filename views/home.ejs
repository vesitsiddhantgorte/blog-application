<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('./partials/head') %>
  <title>Homepage</title>
</head>

<body>
  <%- include('./partials/nav') %>

  <% if (locals.myBlogs && myBlogs.length > 0) { %>
  <div class="container mt-4" id="my-drafts">
    <h4 class="mb-3 fw-bold">My Drafts &amp; Scheduled</h4>
    <div class="row row-cols-1 row-cols-md-3 g-3">
      <% myBlogs.forEach(blog => { %>
      <div class="col">
        <div class="card h-100 border-2 border-warning">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-2">
              <h5 class="card-title mb-0"><%= blog.title %></h5>
              <% if (blog.status === 'draft') { %>
                <span class="badge bg-warning text-dark ms-2">Draft</span>
              <% } else if (blog.status === 'scheduled') { %>
                <span class="badge bg-info text-dark ms-2">Scheduled</span>
              <% } %>
            </div>
            <% if (blog.status === 'scheduled' && blog.scheduledPublishAt) { %>
              <p class="text-muted small mb-2">Publishes at: <%= new Date(blog.scheduledPublishAt).toLocaleString() %></p>
            <% } %>
            <% if (blog.summary) { %>
              <p class="text-muted small mb-2"><%= blog.summary %></p>
            <% } %>
            <div class="d-flex gap-2 mt-auto">
              <a href="/blog/<%= blog._id %>" class="btn btn-outline-primary btn-sm">View</a>
              <a href="/blog/edit/<%= blog._id %>" class="btn btn-warning btn-sm">Edit</a>
            </div>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
  <hr class="container mt-4">
  <% } %>

  <div class="container mt-4">
    <h4 class="mb-3 fw-bold">Published Blogs</h4>
    <div class="row row-cols-1 row-cols-md-3 g-4">
      <% blogs.forEach(blog => { %>
      <div class="col">
        <div class="card h-100">
          <img src="<%= blog.coverImageURL %>" class="card-img-top" alt="cover" style="height:200px;object-fit:cover;">
          <div class="card-body d-flex flex-column">
            <div class="d-flex justify-content-between align-items-start mb-1">
              <h5 class="card-title mb-0"><%= blog.title %></h5>
              <span class="badge bg-success ms-2">Published</span>
            </div>
            <% if (blog.summary) { %>
              <p class="text-muted small mb-2"><%= blog.summary %></p>
            <% } %>
            <div class="d-flex align-items-center mb-3">
              <% if (blog.createdBy && blog.createdBy.profileImageURL) { %>
                <img src="<%= blog.createdBy.profileImageURL %>" width="28" height="28" class="rounded-circle me-2" alt="author" style="object-fit:cover;">
              <% } %>
              <span class="text-muted small">by <%= blog.createdBy && blog.createdBy.fullName ? blog.createdBy.fullName : 'Unknown' %></span>
            </div>
            <div class="mt-auto d-flex gap-2">
              <a href="/blog/<%= blog._id %>" class="btn btn-primary flex-fill">View Blog</a>
              <% if (locals.user && blog.createdBy && blog.createdBy._id.toString() === user._id.toString()) { %>
                <a href="/blog/edit/<%= blog._id %>" class="btn btn-outline-secondary btn-sm">Edit</a>
              <% } %>
            </div>
          </div>
        </div>
      </div>
      <% }) %>
      <% if (blogs.length === 0) { %>
        <p class="text-muted">No published blogs yet.</p>
      <% } %>
    </div>
  </div>

  <%- include('./partials/scripts') %>
  <footer>
    <div>Blogify &copy; 2026. Crafted with ❤️ by you.</div>
  </footer>
</body>

</html>