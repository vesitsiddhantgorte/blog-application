<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('./partials/head') %>
    <title>Edit Blog</title>
</head>

<body>
    <%- include('./partials/nav') %>

    <div class="container d-flex justify-content-center align-items-center" style="min-height: calc(100vh - 160px);">
        <div class="card p-3 shadow" style="max-width: 600px; width:100%;">
            <h2 class="mb-1 text-center">Edit Blog</h2>
            <p class="text-center text-muted mb-2">
                Current Status:
                <% if (blog.status === 'draft') { %>
                    <span class="badge bg-warning text-dark">Draft</span>
                <% } else if (blog.status === 'scheduled') { %>
                    <span class="badge bg-info text-dark">Scheduled</span>
                <% } else { %>
                    <span class="badge bg-success">Published</span>
                <% } %>
            </p>
            <form action="/blog/update/<%= blog._id %>" method="post" enctype="multipart/form-data">
                <div class="mb-2">
                    <label for="coverImage" class="form-label">Cover Image <span class="text-muted small">(leave blank to keep current)</span></label>
                    <% if (blog.coverImageURL) { %>
                        <div class="mb-1">
                            <img src="<%= blog.coverImageURL %>" alt="Current Cover" style="max-height:60px;border-radius:6px;object-fit:cover;">
                        </div>
                    <% } %>
                    <input type="file" class="form-control form-control-sm" id="coverImage" name="coverImage">
                </div>
                <div class="mb-2">
                    <label for="title" class="form-label">Title</label>
                    <input type="text" class="form-control" id="title" name="title" value="<%= blog.title %>" required>
                </div>
                <div class="mb-2">
                    <label for="body" class="form-label">Body</label>
                    <textarea name="body" class="form-control" id="body" rows="3" required><%= blog.body %></textarea>
                </div>
                <div class="mb-2">
                    <label for="status" class="form-label">Status</label>
                    <select class="form-control" name="status" id="status">
                        <option value="draft" <% if (blog.status === 'draft') { %> selected <% } %>>Draft</option>
                        <option value="published" <% if (blog.status === 'published') { %> selected <% } %>>Publish Now</option>
                        <option value="scheduled" <% if (blog.status === 'scheduled') { %> selected <% } %>>Schedule</option>
                    </select>
                </div>
                <div class="mb-2" id="scheduleTimeDiv" style="display:<%= blog.status === 'scheduled' ? 'block' : 'none' %>;">
                    <label for="scheduledPublishAt" class="form-label">Schedule Publish Time</label>
                    <input
                        type="datetime-local"
                        class="form-control"
                        name="scheduledPublishAt"
                        id="scheduledPublishAt"
                        value="<%= blog.scheduledPublishAt ? new Date(blog.scheduledPublishAt).toISOString().slice(0,16) : '' %>"
                    >
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-primary flex-fill" type="submit">Save Changes</button>
                    <a href="/blog/<%= blog._id %>" class="btn btn-outline-secondary flex-fill">Cancel</a>
                </div>
            </form>
        </div>
    </div>

    <%- include('./partials/scripts') %>
    <script>
        document.getElementById('status').addEventListener('change', function () {
            document.getElementById('scheduleTimeDiv').style.display =
                this.value === 'scheduled' ? 'block' : 'none';
        });
    </script>
    <footer>
        <div>Blogify &copy; 2026. Crafted with ❤️ by you.</div>
    </footer>
</body>

</html>
